[Unit]
Description=Photo Production - photo.xaihub.de
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/code/photo
EnvironmentFile=/root/code/photo/.env
Environment=UPLOAD_BASE=/var/www/photo.xaihub.de/downloads
Environment=SITE_DOMAIN=photo.xaihub.de
ExecStart=/root/.local/bin/uv run uvicorn app.main:app --host 127.0.0.1 --port 34109 --no-proxy-headers
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
